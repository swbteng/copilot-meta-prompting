# Copy this file to .env for local runs. Do not commit .env.

# Shared API key for OpenAI-compatible endpoints. Leave empty for local vLLM servers that do not require auth.
RUNPOD_API_KEY=

# Local vLLM defaults used by contests/llm_scripts.py and scripts/rerank_vector_db.py.
HOST=127.0.0.1
LLM_PORT=4000
EMBED_PORT=4001
RERANK_PORT=4002

# Embedding endpoint. scripts/build_vector_db.py and scripts/search_vector_db.py expect the /v1 suffix.
EMBED_BASE_URL=http://127.0.0.1:4001/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B

# Reranker endpoint. scripts/rerank_vector_db.py adds /v1/rerank when needed.
RERANK_BASE_URL=http://127.0.0.1:4002
RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# Optional LLM endpoint for the later selector stage. This repository stops at reranker top-3.
LLM_BASE_URL=http://127.0.0.1:4000
LLM_MODEL=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit

# Chroma artifact defaults.
CHROMA_DIR=artifacts/production_chroma_qwen3_8b
CHROMA_COLLECTION_NAME=production_task_prompt_templates

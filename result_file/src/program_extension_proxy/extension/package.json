{
  "name": "swbc-prompt-refiner",
  "displayName": "Prompt Refiner",
  "description": "Copilot에 보낸 '원본 프롬프트 -> 정제된 프롬프트'를 사이드바에서 보여주는 뷰어 (swbc-proxy 동반 확장).",
  "version": "0.6.0",
  "publisher": "swbc",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "swbc.refine",
        "name": "refine",
        "fullName": "Prompt Refiner",
        "description": "프롬프트를 정제해 미리 보여주고 확인을 받아 Copilot에 보냅니다.",
        "isSticky": false,
        "commands": [
          {
            "name": "bypass",
            "description": "이 텍스트를 정제 없이 그대로 Copilot에 보냅니다(이미 확정된 프롬프트)."
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "swbcPromptRefiner",
          "title": "Prompt Refiner",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "swbcPromptRefiner": [
        {
          "id": "swbcPromptRefiner.rewrites",
          "name": "교체 내역",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "swbcPromptRefiner.refresh",
        "title": "새로고침",
        "category": "Prompt Refiner",
        "icon": "$(refresh)"
      },
      {
        "command": "swbcPromptRefiner.openLogFolder",
        "title": "로그 폴더 열기",
        "category": "Prompt Refiner",
        "icon": "$(folder-opened)"
      },
      {
        "command": "swbcPromptRefiner.toggleEngine",
        "title": "엔진 켜기/끄기",
        "category": "Prompt Refiner"
      },
      {
        "command": "swbcPromptRefiner.startEngine",
        "title": "엔진 켜기",
        "category": "Prompt Refiner"
      },
      {
        "command": "swbcPromptRefiner.stopEngine",
        "title": "엔진 끄기",
        "category": "Prompt Refiner"
      },
      {
        "command": "swbcPromptRefiner.showEngineOutput",
        "title": "엔진 출력 보기",
        "category": "Prompt Refiner",
        "icon": "$(output)"
      },
      {
        "command": "swbcPromptRefiner.setup",
        "title": "셋업 실행 (CA 신뢰 + 프록시)",
        "category": "Prompt Refiner",
        "icon": "$(gear)"
      },
      {
        "command": "swbcPromptRefiner.setupStatus",
        "title": "셋업 상태 보기",
        "category": "Prompt Refiner"
      },
      {
        "command": "swbcPromptRefiner.cleanupSetup",
        "title": "셋업 되돌리기",
        "category": "Prompt Refiner"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "swbcPromptRefiner.refresh",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@1"
        },
        {
          "command": "swbcPromptRefiner.openLogFolder",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@2"
        },
        {
          "command": "swbcPromptRefiner.showEngineOutput",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@3"
        },
        {
          "command": "swbcPromptRefiner.setup",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Prompt Refiner",
      "properties": {
        "swbcPromptRefiner.logDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "교체 로그(`observe-YYYY-MM-DD.log`)가 있는 폴더의 절대경로. 비워두면 확장 전역 저장소(`globalStorage/logs`)를 쓰며, 엔진과 뷰어가 이 폴더를 공유합니다. 옛 `run.sh` 기록(swbc-proxy의 `logs`)을 계속 보려면 그 경로를 여기에 지정하세요."
        },
        "swbcPromptRefiner.maxEntries": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "maximum": 5000,
          "description": "사이드바에 표시할 최근 교체 건수의 최대값."
        },
        "swbcPromptRefiner.autoStart": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "확장이 켜질 때 엔진(mitmdump)을 **자동으로 시작**합니다. `run.sh`로 수동 실행 중이라면 포트 충돌을 피하기 위해 끄세요."
        },
        "swbcPromptRefiner.listenPort": {
          "type": "number",
          "default": 8080,
          "minimum": 1,
          "maximum": 65535,
          "markdownDescription": "엔진(mitmdump) 프록시 포트. VS Code의 `http.proxy` 포트와 **같아야** 트래픽이 흐릅니다(기본 8080)."
        },
        "swbcPromptRefiner.mitmdumpPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "mitmdump 실행 파일 경로. 비우면 **동봉본 -> 워크스페이스 `.venv` -> PATH** 순으로 자동 탐색합니다."
        },
        "swbcPromptRefiner.addonPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "`refine_copilot.py`(애드온) 경로. 비우면 **동봉본 -> 워크스페이스 루트** 순으로 자동 탐색합니다."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  }
}

# ===== swbc-proxy 프로젝트 전용 =====
# 가상환경 (requirements.txt로 재현하므로 커밋하지 않음)
.venv/
venv/
env/

# 교체 로그 (사용자 관측 데이터, 날짜별로 쌓임 - 저장소에 올리지 않음)
logs/
observe-*.log
observe.log

# 내가 만드는 임시 셀프테스트 파일
_selftest_*.py

# ===== VS Code 확장 (extension/) =====
# Node 모듈/패키징 산출물 (소스만 커밋, 생성물은 제외)
node_modules/
*.vsix
.vscode-test/
# 패키징 시 동봉용으로 복사되는 엔진(빌드 산출물, P2 이후 생김)
extension/engine/

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# 테스트/커버리지/타입체크 캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# 환경변수 파일 (비밀값이 들어갈 수 있음)
.env
.env.*

# ===== 에디터 / IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini

# Node 모듈 (런타임 의존성 0이라 평소엔 안 생기지만 방어적으로)
node_modules/

# 패키징 산출물 (.vsix는 소스가 아니라 빌드 결과 — 커밋하지 않음)
*.vsix
!*1.0.0.vsix
!*1.0.1.vsix

# 환경변수 (로컬 엔드포인트/비밀 — .env.example 템플릿만 커밋)

# build.sh가 .env를 vsix에 구워 넣을 때 생성하는 파일(빌드 산출물 — 커밋 안 함, .vsix에는 동봉됨)
src/env.generated.js

# VS Code 확장 테스트 러너 캐시
.vscode-test/

# 임시 셀프테스트 파일 (검증 후 삭제 — 혹시 남아도 커밋 안 되게)
_selftest_*.js

# ===== OS / 에디터 =====
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

docs/*

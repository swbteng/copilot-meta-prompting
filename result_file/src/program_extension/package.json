{
  "name": "copilot-meta-prompting-refiner",
  "displayName": "Prompt Refiner",
  "description": "VS Code Copilot Chat에 @refine를 추가: 프롬프트를 정제해 미리 보여주고 확인 후 전송하며, 정제 내역을 사이드바에 표시합니다.",
  "version": "0.8.0",
  "publisher": "teamPara",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "swbc.refine",
        "name": "refine",
        "fullName": "Prompt Refiner",
        "description": "프롬프트를 정제해 미리 보여주고 확인을 받아 Copilot에 보냅니다.",
        "isSticky": false
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "swbcPromptRefiner",
          "title": "Prompt Refiner",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "swbcPromptRefiner": [
        {
          "id": "swbcPromptRefiner.rewrites",
          "name": "정제 내역",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "swbcPromptRefiner.refresh",
        "title": "새로고침",
        "category": "Prompt Refiner",
        "icon": "$(refresh)"
      },
      {
        "command": "swbcPromptRefiner.openLogFolder",
        "title": "로그 폴더 열기",
        "category": "Prompt Refiner",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "swbcPromptRefiner.refresh",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@1"
        },
        {
          "command": "swbcPromptRefiner.openLogFolder",
          "when": "view == swbcPromptRefiner.rewrites",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Prompt Refiner",
      "properties": {
        "swbcPromptRefiner.logDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "정제 내역 로그(`observe-YYYY-MM-DD.log`)를 두는 폴더의 절대경로. 비우면 확장 전역 저장소(`globalStorage/logs`)를 씁니다. `@refine`에서 정제본을 보내면(allow) 이 폴더에 한 줄씩 기록되고, 사이드바가 같은 폴더를 읽습니다."
        },
        "swbcPromptRefiner.maxEntries": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "maximum": 5000,
          "description": "사이드바에 표시할 최근 정제 건수의 최대값."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  }
}

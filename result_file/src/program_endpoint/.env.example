# program_endpoint 환경설정 예시.
# 이 파일을 .env 로 복사해 값을 채우세요. 실제 키/URL 은 커밋하지 않습니다(.env 는 .gitignore).
# 모든 값은 런타임에 .env(또는 프로세스 환경변수)로만 주입되며 코드에 하드코딩하지 않습니다.
# 값을 바꾸면 코드 수정 없이 그대로 반영됩니다.

# === LLM (텍스트 생성: 정제/최종 프롬프트) — OpenAI 호환 /v1/chat/completions ===
# 예) 로컬 vLLM: http://127.0.0.1:4000   RunPod: https://xxxxxxxx.api.runpod.ai
LLM_BASE_URL=
# 예) cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
LLM_MODEL=
# RunPod 등 인증이 필요할 때만. 로컬 vLLM 은 비워두면 됩니다.
LLM_API_KEY=

# === 임베딩 (벡터 검색용 쿼리 임베딩) — base_url 끝 /v1 자동 보정 ===
# 예) 로컬: http://127.0.0.1:4001/v1   RunPod: https://xxxxxxxx.api.runpod.ai/v1
EMBED_BASE_URL=
# 예) Qwen/Qwen3-Embedding-8B  (DB 구축 시 사용한 모델과 반드시 동일해야 함)
EMBED_MODEL=
EMBED_API_KEY=

# === 리랭커 (검색 후보 재점수화) — base_url 끝에 /v1 을 붙이지 마세요 ===
# 예) 로컬: http://127.0.0.1:4002   RunPod: https://xxxxxxxx.api.runpod.ai
RERANK_BASE_URL=
# 예) Qwen/Qwen3-Reranker-4B
RERANK_MODEL=
RERANK_API_KEY=

# === 세 엔드포인트가 같은 RunPod 키를 쓰면 여기에만 넣어도 됩니다 ===
RUNPOD_API_KEY=

# === Chroma (program_db 에 커밋된 production DB. 비우면 번들 경로/이름으로 폴백) ===
CHROMA_DIR=
CHROMA_COLLECTION_NAME=

# === 검색/리랭킹/타임아웃 (비우면 코드 기본값 사용) ===
CHROMA_TOP_K=
RERANK_TOP_N=
LLM_TIMEOUT=
LLM_MAX_TOKENS=
RERANK_TIMEOUT=
